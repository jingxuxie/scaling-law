+"""Analyze sweep outputs for optimizer-dependent scaling-law experiments.
+
+Usage:
+    python experiments/analyze_results.py \
+      --filter-csv experiments/results/filter_main/filter_sweep.csv \
+      --alignment-csv experiments/results/alignment_main/alignment_sweep.csv
+
+The script prints aggregate errors and writes a Markdown report next to the
+input CSVs.  It is intentionally lightweight: only pandas/numpy are required.
+"""
+
+from __future__ import annotations
+
+import argparse
+from pathlib import Path
+
+import numpy as np
+import pandas as pd
+
+
+def summarize_errors(df: pd.DataFrame, columns: list[str]) -> pd.DataFrame:
+    rows = []
+    for stem in columns:
+        obs = pd.to_numeric(df[f"{stem}_obs"], errors="coerce")
+        pred = pd.to_numeric(df[f"{stem}_pred"], errors="coerce")
+        err = (obs - pred).abs()
+        rows.append(
+            {
+                "metric": stem,
+                "n": int(err.notna().sum()),
+                "mean_abs_error": float(err.mean()),
+                "median_abs_error": float(err.median()),
+                "p90_abs_error": float(err.quantile(0.90)),
+                "max_abs_error": float(err.max()),
+            }
+        )
+    return pd.DataFrame(rows)
+
+
+def flag_filter_rows(df: pd.DataFrame) -> pd.DataFrame:
+    out = df.copy()
+    out["clean_adam_bias_range"] = out["b"] < out["a"] / 2.0 + 1.0
+    out["near_b_equals_1"] = out["b"] <= 1.25
+    # Approximate active Adam count at n_max before damping; useful finite-size flag.
+    out["adam_pre_knee_K_at_nmax"] = out["n_max"] ** (2.0 / out["a"])
+    out["possible_finite_M_saturation"] = out["adam_pre_knee_K_at_nmax"] > 0.25 * out["dimension"]
+    out["comment"] = ""
+    out.loc[~out["clean_adam_bias_range"], "comment"] += "outside clean Adam-bias source range; "
+    out.loc[out["near_b_equals_1"], "comment"] += "slow source tail b close to 1; "
+    out.loc[out["possible_finite_M_saturation"], "comment"] += "possible finite-M saturation; "
+    return out
+
+
+def analyze_filter_csv(path: Path) -> str:
+    df = pd.read_csv(path)
+    count_metrics = ["sgd_count_slope", "adam_count_slope", "adamw_count_slope"]
+    bias_metrics = ["sgd_bias_slope", "adam_bias_slope", "adamw_bias_slope"]
+    count_summary = summarize_errors(df, count_metrics)
+    bias_summary = summarize_errors(df, bias_metrics)
+    flagged = flag_filter_rows(df)
+
+    clean_mid = flagged[(flagged["b"].between(1.3, 1.6)) & (flagged["clean_adam_bias_range"])]
+    clean_summary = summarize_errors(clean_mid, count_metrics + bias_metrics) if len(clean_mid) else pd.DataFrame()
+
+    worst = flagged.assign(adam_bias_err=(flagged["adam_bias_slope_obs"] - flagged["adam_bias_slope_pred"]).abs())
+    worst = worst.sort_values("adam_bias_err", ascending=False).head(10)
+
+    report = []
+    report.append("# Sweep results review\n")
+    report.append(f"Input: `{path}`\n")
+    report.append(f"Rows: {len(df)}\n")
+    report.append("## Count-slope errors\n")
+    report.append(count_summary.to_markdown(index=False))
+    report.append("\n\n## Bias-slope errors\n")
+    report.append(bias_summary.to_markdown(index=False))
+    if len(clean_mid):
+        report.append("\n\n## Clean middle-regime errors\n")
+        report.append(clean_summary.to_markdown(index=False))
+    report.append("\n\n## Largest Adam-bias discrepancies\n")
+    cols = [
+        "a", "b", "rho", "wd", "adam_bias_slope_obs", "adam_bias_slope_pred",
+        "adam_bias_err", "comment",
+    ]
+    report.append(worst[cols].to_markdown(index=False))
+    text = "\n".join(report) + "\n"
+    out_path = path.parent / "filter_sweep_review.md"
+    out_path.write_text(text)
+    return text
+
+
+def analyze_alignment_csv(path: Path) -> str:
+    df = pd.read_csv(path)
+    metrics = ["original_slope", "aligned_slope", "flat_slope", "random_slope"]
+    summary = summarize_errors(df, metrics)
+    df = df.copy()
+    df["random_closer_to_flat_than_aligned"] = (
+        (df["random_slope_obs"] - df["flat_slope_pred"]).abs()
+        < (df["random_slope_obs"] - df["aligned_slope_pred"]).abs()
+    )
+    frac = float(df["random_closer_to_flat_than_aligned"].mean())
+    report = []
+    report.append("# Coordinate-alignment sweep review\n")
+    report.append(f"Input: `{path}`\n")
+    report.append(f"Rows: {len(df)}\n")
+    report.append("## Slope errors\n")
+    report.append(summary.to_markdown(index=False))
+    report.append("\n\n## Random-rotation diagnostic\n")
+    report.append(f"Fraction of random rows closer to flat/SGD slope than aligned slope: `{frac:.3f}`\n")
+    report.append("\n")
+    report.append(df[["dimension", "a", "rho", "random_slope_obs", "flat_slope_pred", "aligned_slope_pred", "random_diag_condition", "random_diag_slope", "random_closer_to_flat_than_aligned"]].to_markdown(index=False))
+    text = "\n".join(report) + "\n"
+    out_path = path.parent / "alignment_sweep_review.md"
+    out_path.write_text(text)
+    return text
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--filter-csv", type=Path, default=Path("experiments/results/filter_main/filter_sweep.csv"))
+    parser.add_argument("--alignment-csv", type=Path, default=Path("experiments/results/alignment_main/alignment_sweep.csv"))
+    args = parser.parse_args()
+
+    if args.filter_csv.exists():
+        print(analyze_filter_csv(args.filter_csv))
+    else:
+        print(f"Missing filter CSV: {args.filter_csv}")
+
+    if args.alignment_csv.exists():
+        print(analyze_alignment_csv(args.alignment_csv))
+    else:
+        print(f"Missing alignment CSV: {args.alignment_csv}")
+
+
+if __name__ == "__main__":
+    main()
