@@ -0,0 +1,275 @@
+"""Stochastic training scaling experiments for diagonal Gaussian regression.
+
+This script complements the deterministic filter sweeps by actually training
+SGD / oracle RMSProp / frozen RMSProp / RMSProp / Adam / AdamW on diagonal
+Gaussian linear regression.
+
+The goal is not to replace the deterministic filter theorem; it is to check that
+actual stochastic optimizers move in the predicted direction.  Defaults are
+small enough for a laptop smoke test.  Increase --dimension, --n-values, and
+--reps for paper-quality plots.
+
+Example smoke test:
+  python experiments/stochastic_training_scaling.py --quick
+
+Larger run:
+  python experiments/stochastic_training_scaling.py \
+      --dimension 4096 --a 1.5 --b 1.4 \
+      --n-values 250,500,1000,2000,4000,8000 \
+      --algorithms sgd,oracle_rmsprop,frozen_rmsprop,rmsprop,adam,adamw \
+      --reps 5 --batch-size 16
+"""
+
+from __future__ import annotations
+
+import argparse
+import csv
+import json
+import math
+from pathlib import Path
+
+import numpy as np
+
+try:
+    import matplotlib.pyplot as plt
+except Exception:  # pragma: no cover
+    plt = None
+
+
+def parse_list(text: str, typ=float):
+    return [typ(x.strip()) for x in text.split(",") if x.strip()]
+
+
+def fit_slope(x: np.ndarray, y: np.ndarray) -> float:
+    x = np.asarray(x, dtype=float)
+    y = np.asarray(y, dtype=float)
+    mask = np.isfinite(x) & np.isfinite(y) & (x > 0) & (y > 0)
+    if mask.sum() < 3:
+        return float("nan")
+    X = np.vstack([np.ones(mask.sum()), np.log(x[mask])]).T
+    coef, *_ = np.linalg.lstsq(X, np.log(y[mask]), rcond=None)
+    return float(coef[1])
+
+
+def make_problem(d: int, a: float, b: float, sigma: float, rng: np.random.Generator):
+    idx = np.arange(1, d + 1, dtype=float)
+    lam = idx ** (-a)
+    lam /= lam[0]
+    source = idx ** (-b)
+    signs = rng.choice([-1.0, 1.0], size=d)
+    w_star = signs * np.sqrt(source / lam)
+    return lam, source, w_star, sigma
+
+
+def exact_excess_risk(w: np.ndarray, w_star: np.ndarray, lam: np.ndarray) -> float:
+    e = w - w_star
+    return float(np.sum(lam * e * e))
+
+
+def sample_batch(rng: np.random.Generator, lam: np.ndarray, w_star: np.ndarray, sigma: float, batch_size: int):
+    X = rng.normal(size=(batch_size, len(lam))) * np.sqrt(lam)[None, :]
+    y = X @ w_star + rng.normal(scale=sigma, size=batch_size)
+    return X, y
+
+
+def gradient_batch(X: np.ndarray, y: np.ndarray, w: np.ndarray) -> np.ndarray:
+    residual = X @ w - y
+    return X.T @ residual / len(y)
+
+
+def estimate_v0(
+    rng: np.random.Generator,
+    lam: np.ndarray,
+    w_star: np.ndarray,
+    sigma: float,
+    batch_size: int,
+    batches: int,
+) -> np.ndarray:
+    v = np.zeros_like(lam)
+    w0 = np.zeros_like(lam)
+    for _ in range(batches):
+        X, y = sample_batch(rng, lam, w_star, sigma, batch_size)
+        g = gradient_batch(X, y, w0)
+        v += g * g
+    return v / max(batches, 1)
+
+
+def train_one(
+    algorithm: str,
+    N: int,
+    lam: np.ndarray,
+    w_star: np.ndarray,
+    sigma: float,
+    lr: float,
+    batch_size: int,
+    rng: np.random.Generator,
+    rho: float,
+    eps: float,
+    beta1: float,
+    beta2: float,
+    weight_decay: float,
+    burnin_batches: int,
+) -> float:
+    d = len(lam)
+    w = np.zeros(d, dtype=float)
+    m = np.zeros(d, dtype=float)
+    v = np.zeros(d, dtype=float)
+
+    if algorithm == "oracle_rmsprop":
+        precond = 1.0 / np.sqrt(lam + rho)
+    elif algorithm == "frozen_rmsprop":
+        vhat = estimate_v0(rng, lam, w_star, sigma, batch_size, burnin_batches)
+        # Normalize out the global residual scale so that eps acts like rho.
+        vhat = vhat / max(np.median(vhat / lam), 1e-300)
+        precond = 1.0 / np.sqrt(vhat + rho)
+    else:
+        precond = None
+
+    steps = math.ceil(N / batch_size)
+    seen = 0
+    for t in range(1, steps + 1):
+        bsz = min(batch_size, N - seen)
+        if bsz <= 0:
+            break
+        seen += bsz
+        X, y = sample_batch(rng, lam, w_star, sigma, bsz)
+        g = gradient_batch(X, y, w)
+
+        if algorithm == "sgd":
+            w -= lr * g
+        elif algorithm in {"oracle_rmsprop", "frozen_rmsprop"}:
+            w -= lr * precond * g
+        elif algorithm == "rmsprop":
+            v = beta2 * v + (1.0 - beta2) * (g * g)
+            w -= lr * g / np.sqrt(v + eps)
+        elif algorithm == "adam":
+            m = beta1 * m + (1.0 - beta1) * g
+            v = beta2 * v + (1.0 - beta2) * (g * g)
+            mhat = m / (1.0 - beta1 ** t)
+            vhat = v / (1.0 - beta2 ** t)
+            w -= lr * mhat / np.sqrt(vhat + eps)
+        elif algorithm == "adamw":
+            m = beta1 * m + (1.0 - beta1) * g
+            v = beta2 * v + (1.0 - beta2) * (g * g)
+            mhat = m / (1.0 - beta1 ** t)
+            vhat = v / (1.0 - beta2 ** t)
+            w *= 1.0 - lr * weight_decay
+            w -= lr * mhat / np.sqrt(vhat + eps)
+        else:
+            raise ValueError(f"unknown algorithm: {algorithm}")
+    return exact_excess_risk(w, w_star, lam)
+
+
+def maybe_plot(outdir: Path, rows: list[dict[str, float | str]], no_plots: bool) -> None:
+    if no_plots or plt is None:
+        return
+    plot_dir = outdir / "plots"
+    plot_dir.mkdir(parents=True, exist_ok=True)
+    algs = sorted(set(str(r["algorithm"]) for r in rows))
+    fig = plt.figure()
+    for alg in algs:
+        sub = [r for r in rows if r["algorithm"] == alg]
+        Ns = np.array([float(r["N"]) for r in sub])
+        risks = np.array([float(r["risk_mean"]) for r in sub])
+        order = np.argsort(Ns)
+        plt.loglog(Ns[order], risks[order], marker="o", label=alg)
+    plt.xlabel("N samples")
+    plt.ylabel("excess risk")
+    plt.legend()
+    plt.tight_layout()
+    fig.savefig(plot_dir / "risk_vs_N.png", dpi=160)
+    plt.close(fig)
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--outdir", type=Path, default=Path("experiments/results/stochastic_training"))
+    parser.add_argument("--dimension", type=int, default=2048)
+    parser.add_argument("--a", type=float, default=1.5)
+    parser.add_argument("--b", type=float, default=1.4)
+    parser.add_argument("--sigma", type=float, default=0.1)
+    parser.add_argument("--n-values", type=str, default="250,500,1000,2000,4000")
+    parser.add_argument("--algorithms", type=str, default="sgd,oracle_rmsprop,frozen_rmsprop,rmsprop,adam,adamw")
+    parser.add_argument("--lr", type=float, default=0.03)
+    parser.add_argument("--batch-size", type=int, default=16)
+    parser.add_argument("--reps", type=int, default=3)
+    parser.add_argument("--rho", type=float, default=1e-8)
+    parser.add_argument("--eps", type=float, default=1e-8)
+    parser.add_argument("--beta1", type=float, default=0.9)
+    parser.add_argument("--beta2", type=float, default=0.99)
+    parser.add_argument("--weight-decay", type=float, default=1e-3)
+    parser.add_argument("--burnin-batches", type=int, default=64)
+    parser.add_argument("--seed", type=int, default=0)
+    parser.add_argument("--quick", action="store_true")
+    parser.add_argument("--no-plots", action="store_true")
+    args = parser.parse_args()
+
+    if args.quick:
+        args.dimension = 512
+        args.n_values = "100,200,400,800"
+        args.algorithms = "sgd,oracle_rmsprop,frozen_rmsprop,adamw"
+        args.reps = 2
+        args.batch_size = 16
+        args.outdir = Path("experiments/results/stochastic_training_quick")
+
+    outdir = args.outdir
+    outdir.mkdir(parents=True, exist_ok=True)
+    rng_master = np.random.default_rng(args.seed)
+    N_values = [int(x) for x in parse_list(args.n_values, int)]
+    algorithms = [x.strip() for x in args.algorithms.split(",") if x.strip()]
+
+    rows = []
+    for alg in algorithms:
+        for N in N_values:
+            risks = []
+            for rep in range(args.reps):
+                rng = np.random.default_rng(int(rng_master.integers(0, 2**32 - 1)))
+                lam, source, w_star, sigma = make_problem(args.dimension, args.a, args.b, args.sigma, rng)
+                risk = train_one(
+                    alg, N, lam, w_star, sigma, args.lr, args.batch_size, rng,
+                    args.rho, args.eps, args.beta1, args.beta2, args.weight_decay,
+                    args.burnin_batches,
+                )
+                risks.append(risk)
+            row = {
+                "algorithm": alg,
+                "N": N,
+                "risk_mean": float(np.mean(risks)),
+                "risk_std": float(np.std(risks, ddof=1)) if len(risks) > 1 else 0.0,
+                "reps": args.reps,
+                "dimension": args.dimension,
+                "a": args.a,
+                "b": args.b,
+                "lr": args.lr,
+                "batch_size": args.batch_size,
+                "rho": args.rho,
+                "eps": args.eps,
+                "weight_decay": args.weight_decay,
+            }
+            rows.append(row)
+            print(f"alg={alg:16s} N={N:6d} risk={row['risk_mean']:.4e} ± {row['risk_std']:.2e}")
+
+    # Add slopes by algorithm.
+    slope_rows = []
+    for alg in algorithms:
+        sub = [r for r in rows if r["algorithm"] == alg]
+        Ns = np.array([float(r["N"]) for r in sub])
+        risks = np.array([float(r["risk_mean"]) for r in sub])
+        slope_rows.append({"algorithm": alg, "risk_slope_vs_N": fit_slope(Ns, risks)})
+
+    with (outdir / "training_risks.csv").open("w", newline="") as f:
+        writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
+        writer.writeheader()
+        writer.writerows(rows)
+    with (outdir / "training_slopes.csv").open("w", newline="") as f:
+        writer = csv.DictWriter(f, fieldnames=list(slope_rows[0].keys()))
+        writer.writeheader()
+        writer.writerows(slope_rows)
+    with (outdir / "config.json").open("w") as f:
+        json.dump(vars(args), f, indent=2, sort_keys=True, default=str)
+    maybe_plot(outdir, rows, args.no_plots)
+    print(f"Wrote results to {outdir}")
+
+
+if __name__ == "__main__":
+    main()
