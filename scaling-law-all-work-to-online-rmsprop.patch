+r"""Online RMSProp spectral-tracking sanity check.
+
+This experiment tests the theorem in notes/04_online_rmsprop_tracking.md.
+In diagonal Gaussian linear regression, online RMSProp should maintain
+
+    v_{t,i} \propto c_t lambda_i,
+
+so the preconditioner should have effective spectral exponent q_eff ~= 1/2
+on coordinates where epsilon is not the bottleneck.
+
+Run:
+    python experiments/online_rmsprop_tracking.py
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+from dataclasses import asdict, dataclass
+from typing import Any
+
+import numpy as np
+
+
+@dataclass
+class TrackingSummary:
+    dim: int
+    steps: int
+    a: float
+    b: float
+    sigma: float
+    beta2: float
+    epsilon: float
+    eta: float
+    final_c_t: float
+    final_rho_t: float
+    final_slope_log_v_vs_log_lambda: float
+    final_q_eff: float
+    final_median_mu_ratio: float
+    final_median_abs_log_mu_ratio: float
+    median_tail_slope_log_v_vs_log_lambda: float
+    median_tail_q_eff: float
+    median_tail_mu_ratio: float
+
+
+def make_problem(
+    dim: int,
+    a: float,
+    b: float,
+    rng: np.random.Generator,
+) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
+    idx = np.arange(1, dim + 1, dtype=float)
+    lam = idx ** (-a)
+    source_energy = idx ** (-b)  # s_i = lambda_i (w_i*)^2
+    signs = rng.choice(np.array([-1.0, 1.0]), size=dim)
+    w_star = signs * np.sqrt(source_energy / lam)
+    return idx, lam, w_star
+
+
+def slope(x: np.ndarray, y: np.ndarray) -> float:
+    if x.size < 2:
+        return float("nan")
+    return float(np.polyfit(x, y, deg=1)[0])
+
+
+def run_experiment(args: argparse.Namespace) -> dict[str, Any]:
+    rng = np.random.default_rng(args.seed)
+    idx, lam, w_star = make_problem(args.dim, args.a, args.b, rng)
+
+    w = np.zeros(args.dim)
+    v = np.zeros(args.dim)
+    records: list[dict[str, float]] = []
+
+    coord = np.arange(args.dim)
+    base_coord_mask = (coord >= args.min_coord) & (coord < args.max_coord)
+
+    for t in range(1, args.steps + 1):
+        x = rng.normal(loc=0.0, scale=np.sqrt(lam))
+        y = float(x @ w_star + rng.normal(scale=args.sigma))
+        residual = float(x @ w - y)
+        g = residual * x
+
+        v = args.beta2 * v + (1.0 - args.beta2) * (g * g)
+        v_hat = v / max(1.0 - args.beta2**t, 1e-300)
+        precond = 1.0 / np.sqrt(v_hat + args.epsilon)
+        w -= args.eta * precond * g
+
+        if t % args.log_every == 0 or t == args.steps:
+            e = w - w_star
+            c_t = float(args.sigma**2 + np.sum(lam * e * e))
+            rho_t = float(args.epsilon / c_t)
+
+            # Avoid coordinates where epsilon dominates, since the theorem predicts
+            # q_eff ~= 1/2 only before the epsilon/damping knee.
+            active = (v_hat > args.epsilon_multiplier * args.epsilon) & base_coord_mask
+            if int(np.sum(active)) < 20:
+                active = base_coord_mask
+
+            log_lam = np.log(lam[active])
+            log_v = np.log(v_hat[active] + 1e-300)
+            log_p = np.log(precond[active])
+
+            slope_v = slope(log_lam, log_v)
+            q_eff = -slope(log_lam, log_p)
+
+            mu_emp = lam * precond
+            mu_pop = (c_t ** -0.5) * lam / np.sqrt(lam + rho_t)
+            ratio = mu_emp[active] / mu_pop[active]
+            median_ratio = float(np.median(ratio))
+            median_abs_log_ratio = float(np.median(np.abs(np.log(ratio))))
+
+            records.append(
+                {
+                    "step": float(t),
+                    "c_t": c_t,
+                    "rho_t": rho_t,
+                    "slope_log_v_vs_log_lambda": slope_v,
+                    "q_eff": q_eff,
+                    "median_mu_ratio": median_ratio,
+                    "median_abs_log_mu_ratio": median_abs_log_ratio,
+                    "num_active_coords": float(np.sum(active)),
+                }
+            )
+
+    tail = records[-max(1, args.tail_records) :]
+    summary = TrackingSummary(
+        dim=args.dim,
+        steps=args.steps,
+        a=args.a,
+        b=args.b,
+        sigma=args.sigma,
+        beta2=args.beta2,
+        epsilon=args.epsilon,
+        eta=args.eta,
+        final_c_t=records[-1]["c_t"],
+        final_rho_t=records[-1]["rho_t"],
+        final_slope_log_v_vs_log_lambda=records[-1]["slope_log_v_vs_log_lambda"],
+        final_q_eff=records[-1]["q_eff"],
+        final_median_mu_ratio=records[-1]["median_mu_ratio"],
+        final_median_abs_log_mu_ratio=records[-1]["median_abs_log_mu_ratio"],
+        median_tail_slope_log_v_vs_log_lambda=float(
+            np.median([r["slope_log_v_vs_log_lambda"] for r in tail])
+        ),
+        median_tail_q_eff=float(np.median([r["q_eff"] for r in tail])),
+        median_tail_mu_ratio=float(np.median([r["median_mu_ratio"] for r in tail])),
+    )
+
+    return {"summary": asdict(summary), "records": records}
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--dim", type=int, default=1024)
+    parser.add_argument("--steps", type=int, default=3000)
+    parser.add_argument("--a", type=float, default=1.6)
+    parser.add_argument("--b", type=float, default=1.4)
+    parser.add_argument("--sigma", type=float, default=0.1)
+    parser.add_argument("--beta2", type=float, default=0.99)
+    parser.add_argument("--epsilon", type=float, default=1e-6)
+    parser.add_argument("--eta", type=float, default=0.002)
+    parser.add_argument("--seed", type=int, default=0)
+    parser.add_argument("--log-every", type=int, default=200)
+    parser.add_argument("--tail-records", type=int, default=5)
+    parser.add_argument("--epsilon-multiplier", type=float, default=10.0)
+    parser.add_argument("--min-coord", type=int, default=10)
+    parser.add_argument("--max-coord", type=int, default=512)
+    return parser
+
+
+def main() -> None:
+    args = build_parser().parse_args()
+    result = run_experiment(args)
+    print(json.dumps(result["summary"], indent=2, sort_keys=True))
+
+
+if __name__ == "__main__":
+    main()
